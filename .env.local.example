# ─────────────────────────────────────────────────────────────────────────────
# Haiti City Portal — Environment Variables
#
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
#
# Required variables are marked  ← REQUIRED
# Optional variables are marked  ← OPTIONAL (defaults shown)
# ─────────────────────────────────────────────────────────────────────────────


# ─── DATABASE ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local dev  : postgresql://postgres:password@localhost:5432/haiticityportal
# Neon prod  : postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/haiticityportal"  # ← REQUIRED


# ─── AUTHENTICATION (next-auth v5) ───────────────────────────────────────────

# Random 32+ character secret used to sign session tokens.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=""  # ← REQUIRED

# The canonical public URL of the app (used by next-auth for redirects).
NEXTAUTH_URL="http://localhost:3000"  # ← REQUIRED in production

# Set to true when running behind a trusted reverse proxy (Vercel, Nginx, etc.)
AUTH_TRUST_HOST="true"  # ← OPTIONAL


# ─── APPLICATION ─────────────────────────────────────────────────────────────

# Base URL used for generating absolute links (breadcrumbs, OG images, etc.)
# Defaults to http://localhost:3000 when not set.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"  # ← OPTIONAL

# Bypass the database entirely and serve mock/sample data.
# Set to "true" in local dev if you don't have a DB running.
# Automatically true in non-production environments.
ENABLE_LOCAL_MODE="true"  # ← OPTIONAL


# ─── PRODUCTION SEED GUARD ───────────────────────────────────────────────────

# Must be set to "yes" to allow npm run db:seed:prod to execute.
# This prevents accidental data overwrites on production databases.
# CONFIRM_PRODUCTION_SEED="yes"  # ← OPTIONAL (uncomment only when intentionally seeding prod)


# ─── PRODUCTION SEED CREDENTIALS ─────────────────────────────────────────────
# Used only by src/db/seed.production.ts — never hardcoded.
# Must be strong, unique passwords. Generate with:  openssl rand -base64 24

# SEED_ADMIN_EMAIL="admin@yourdomain.ht"
# SEED_ADMIN_PASSWORD=""
# SEED_TENANT_NAME="Ville de Jacmel"
# SEED_TENANT_SUBDOMAIN="jacmel"
